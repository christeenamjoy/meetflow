// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
    generatorVersion = "client"

}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id @default(uuid())
  email        String        @unique
  username     String        @unique
  clerkUserId  String        @unique
  name         String?
  imageUrl     String?
  bookings     Booking[]     @relation("UserBookings")
  events       Event[]       @relation("UserEvents")
  availability Availability?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Booking {
  id             Int      @id @default(autoincrement())
  User           User     @relation("UserBookings", fields: [userId], references: [id])
  userId         String
  Event          Event    @relation(fields: [eventId], references: [id], onDelete: Cascade) // If an event is deleted all of the related booking also will be deleted.
  eventId        Int
  name           String
  email          String
  additionalInfo String?
  startTime      DateTime
  endTime        DateTime
  meetingLink    String?
  googleEventId  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Event {
  id          Int       @id @default(autoincrement())
  title       String
  description String
  duration    Int
  userId      String
  user        User      @relation("UserEvents", fields: [userId], references: [id])
  bookings    Booking[]
  isPrivate   Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Availability {
  id        Int      @id @default(autoincrement())
  userId    String   @unique
  timeGap   Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  days DaysAvailability[]
}

model DaysAvailability {
  id             Int          @id @default(autoincrement())
  availabilityId Int
  day            DaysOfWeek
  startTime      DateTime
  endTime        DateTime
  availability   Availability @relation(fields: [availabilityId], references: [id], onDelete: Cascade)
}

enum DaysOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
}
